#: src/cli.cpp:37
msgctxt "Cli|"
msgid "Display all language codes."
msgstr "Zobraziť všetky kódy jazykov."

#: src/cli.cpp:39
msgctxt "Cli|"
msgid ""
"Specify the source language (by default, engine will try to determine the "
"language on its own)."
msgstr ""
"Zadať zdrojový jazyk (predvolene sa prekladač pokúsi určiť jazyk "
"automaticky)."

#: src/cli.cpp:43
msgctxt "Cli|"
msgid ""
"Specify the translation language(s), split by '+' (by default, the system "
"language is used)."
msgstr ""
"Zadať cieľový jazyk/jazyky, oddelené '+' (predvolene sa používa systémový "
"jazyk)."

#: src/cli.cpp:47
msgctxt "Cli|"
msgid ""
"Specify the translator engine ('google', 'yandex', 'bing', 'libretranslate' "
"or 'lingva'), Google is used by default."
msgstr ""
"Zadať prekladový mechanizmus ('google', 'yandex', 'bing', 'libretranslate' "
"alebo 'lingva'), predvolene sa používa Google."

#: src/cli.cpp:51
msgctxt "Cli|"
msgid ""
"Specify Mozhi instance URL. Instance URL from the app settings will be used "
"by default."
msgstr ""
"Zadať URL inštancie Mozhi. Predvolene sa použije URL inštancie z nastavení "
"aplikácie."

#: src/cli.cpp:55
msgctxt "Cli|"
msgid ""
"Specify translation provider ('copy' or 'mozhi'). Provider from app settings "
"will be used by default."
msgstr ""
"Zadať poskytovateľa prekladu ('copy' alebo 'mozhi'). Predvolene sa použije "
"poskytovateľ z nastavení aplikácie."

#: src/cli.cpp:58
msgctxt "Cli|"
msgid ""
"Specify TTS provider ('none', 'mozhi', 'qt', or 'piper'). Provider from app "
"settings will be used by default."
msgstr ""
"Zadať poskytovateľa TTS ('none', 'mozhi', 'qt' alebo 'piper'). Predvolene sa "
"použije poskytovateľ z nastavení aplikácie."

#: src/cli.cpp:60
msgctxt "Cli|"
msgid "Speak the translation."
msgstr "Prečítať preklad."

#: src/cli.cpp:61
msgctxt "Cli|"
msgid "Speak the source."
msgstr "Prečítať zdroj."

#: src/cli.cpp:62
msgctxt "Cli|"
msgid ""
"Read source text from files. Arguments will be interpreted as file paths."
msgstr ""
"Čítať zdrojový text zo súborov. Argumenty budú interpretované ako cesty k "
"súborom."

#: src/cli.cpp:63
msgctxt "Cli|"
msgid "Add stdin data to source text."
msgstr "Pridať dáta zo stdin k zdrojovému textu."

#: src/cli.cpp:65
#, qt-format
msgctxt "Cli|"
msgid "Do not print any text when using --%1 or --%2."
msgstr "Nevypisovať žiadny text pri použití --%1 alebo --%2."

#: src/cli.cpp:66
msgctxt "Cli|"
msgid "Print only translations."
msgstr "Vypísať iba preklady."

#: src/cli.cpp:67
msgctxt "Cli|"
msgid "Print output formatted as JSON."
msgstr "Vypísať výstup formátovaný ako JSON."

#: src/cli.cpp:70
msgctxt "Cli|"
msgid ""
"Application that allows to translate and speak text using various providers"
msgstr ""
"Aplikácia, ktorá umožňuje prekladať a čítať text pomocou rôznych "
"poskytovateľov"

#: src/cli.cpp:71
msgctxt "Cli|"
msgid ""
"Text to translate. By default, the translation will be done to the system "
"language."
msgstr "Text na preklad. Predvolene sa preloží do systémového jazyka."

