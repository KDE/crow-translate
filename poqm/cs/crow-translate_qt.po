#: src/cli.cpp:37
msgctxt "Cli|"
msgid "Display all language codes."
msgstr "Zobrazit všechny jazykové kódy."

#: src/cli.cpp:39
msgctxt "Cli|"
msgid ""
"Specify the source language (by default, engine will try to determine the "
"language on its own)."
msgstr ""
"Zadejte zdrojový jazyk (ve výchozím nastavení se modul pokusí jazyk určit "
"sám)."

#: src/cli.cpp:43
msgctxt "Cli|"
msgid ""
"Specify the translation language(s), split by '+' (by default, the system "
"language is used)."
msgstr ""
"Zadejte jazyk(y) překladu, oddělené znakem '+' (ve výchozím nastavení se "
"použije jazyk systému)."

#: src/cli.cpp:47
msgctxt "Cli|"
msgid ""
"Specify the translator engine ('google', 'yandex', 'bing', 'libretranslate' "
"or 'lingva'), Google is used by default."
msgstr ""
"Zadejte překladatelské jádro ('google', 'yandex', 'bing', 'libretranslate' "
"nebo 'lingva'); ve výchozím nastavení se používá Google."

#: src/cli.cpp:51
msgctxt "Cli|"
msgid ""
"Specify Mozhi instance URL. Instance URL from the app settings will be used "
"by default."
msgstr ""
"Zadejte URL instance Mozhi. Ve výchozím nastavení se použije URL instance z "
"nastavení aplikace."

#: src/cli.cpp:55
msgctxt "Cli|"
msgid ""
"Specify translation provider ('copy' or 'mozhi'). Provider from app settings "
"will be used by default."
msgstr ""
"Zadejte poskytovatele překladu ('copy' nebo 'mozhi'). Ve výchozím nastavení "
"se použije poskytovatel z nastavení aplikace."

#: src/cli.cpp:58
msgctxt "Cli|"
msgid ""
"Specify TTS provider ('none', 'mozhi', 'qt', or 'piper'). Provider from app "
"settings will be used by default."
msgstr ""
"Zadejte poskytovatele služby TTS ('none', 'mozhi', 'qt' nebo 'piper'). Ve "
"výchozím nastavení se použije poskytovatel z nastavení aplikace."

#: src/cli.cpp:60
msgctxt "Cli|"
msgid "Speak the translation."
msgstr "Přečíst překlad."

#: src/cli.cpp:61
msgctxt "Cli|"
msgid "Speak the source."
msgstr "Přečíst zdroj."

#: src/cli.cpp:62
msgctxt "Cli|"
msgid ""
"Read source text from files. Arguments will be interpreted as file paths."
msgstr ""
"Načte zdrojový text ze souborů. Argumenty budou interpretovány jako cesty k "
"souborům."

#: src/cli.cpp:63
msgctxt "Cli|"
msgid "Add stdin data to source text."
msgstr "Přidá data ze standardního vstupu ke zdrojovému textu."

#: src/cli.cpp:65
#, qt-format
msgctxt "Cli|"
msgid "Do not print any text when using --%1 or --%2."
msgstr "Při použití parametrů --%1 nebo --%2 nevytisknete žádný text."

#: src/cli.cpp:66
msgctxt "Cli|"
msgid "Print only translations."
msgstr "Tisknout pouze překlady."

#: src/cli.cpp:67
msgctxt "Cli|"
msgid "Print output formatted as JSON."
msgstr "Tisknout výstup ve formátu JSON."

#: src/cli.cpp:70
msgctxt "Cli|"
msgid ""
"Application that allows to translate and speak text using various providers"
msgstr ""
"Aplikace, která umožňuje překládat a přečíst texty s využitím různých "
"poskytovatelů služeb"

#: src/cli.cpp:71
msgctxt "Cli|"
msgid ""
"Text to translate. By default, the translation will be done to the system "
"language."
msgstr ""
"Text k překladu. Ve výchozím nastavení bude překlad proveden do jazyka "
"systému."

